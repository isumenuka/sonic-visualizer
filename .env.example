# ── Sonic Visualizer — Environment Variables ──────────────────────────────────

# URL of the Render.com service that hosts FFmpeg WASM core files.
# Example: https://sonic-ffmpeg.onrender.com
#
# During development (npm run dev), FFmpeg files are loaded from /public/ffmpeg/
# so this variable is optional locally.
#
# In production (Vercel), set this to your Render.com Web Service URL.
VITE_FFMPEG_BASE_URL=https://your-render-service.onrender.com
